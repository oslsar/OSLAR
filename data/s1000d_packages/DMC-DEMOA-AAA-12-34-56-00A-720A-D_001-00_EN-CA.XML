            </supplyDescr>
          </supplyDescrGroup>
        </reqSupplies>
        <reqPersons>
          <person personCategoryCode="maintainer" numRequired="1"/>
        </reqPersons>
      </preliminaryRqmts>
      <mainProcedure>
        <proceduralStep>
          <para>Put the bicycle on a work stand.</para>
        </proceduralStep>
        <proceduralStep>
          <para>Use the chain breaker tool to disconnect the chain.</para>
        </proceduralStep>
        <proceduralStep>
          <para>Remove the chain from the front chainring and rear sprocket.</para>
        </proceduralStep>
        <proceduralStep>
          <para>Install the replacement chain and connect the master link.</para>
        </proceduralStep>
        <proceduralStep>
          <para>Lubricate the chain and make sure the chain moves freely.</para>
        </proceduralStep>
      </mainProcedure>
      <closeRqmts>
        <reqCondGroup>
          <reqCond>
            <para>Chain installed and lubricated.</para>
          </reqCond>
        </reqCondGroup>
      </closeRqmts>
    </procedure>
