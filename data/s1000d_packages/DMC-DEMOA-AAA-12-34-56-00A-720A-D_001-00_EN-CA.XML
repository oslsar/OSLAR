  <content>
    <procedure>
      <preliminaryRqmts>
        <reqSupportEquips>
          <supportEquipDescrGroup>
            <supportEquipDescr>
              <name>Chain breaker tool</name>
            </supportEquipDescr>
          </supportEquipDescrGroup>
        </reqSupportEquips>
        <reqSupplies>
          <supplyDescrGroup>
            <supplyDescr>
